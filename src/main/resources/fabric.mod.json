		"sources": "https://github.com/HSSkyBoy/LifeDebt"
	},
	"license": "Apache-2.0",
	"icon": "assets/lifedebt/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.adoleiiiiii.lifedebt.LifeDebt"
		]
	},
	"mixins": [
		"lifedebt.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~${minecraft_version}",
		"java": ">=${java_version}",
		"fabric-api": "*"
	}
